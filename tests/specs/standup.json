[
  {
    "name": "Open standup menu",
    "steps": [
      {
        "send": { "callback": "standup:menu" },
        "expect": [
          { "method": "editMessageText", "payload": { "text": "📊 Standup — pick an action:" } }
        ]
      }
    ]
  },
  {
    "name": "Pick team without any teams shows empty state",
    "steps": [
      {
        "send": { "callback": "standup:pickteam" },
        "expect": [
          { "method": "editMessageText", "payload": { "text": "No teams yet. Create a team first with 🔧 Teams." } }
        ]
      }
    ]
  }
